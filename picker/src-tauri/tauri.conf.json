{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenCode Model Dispatch Picker",
  "version": "0.0.0",
  "identifier": "com.opencode.model-dispatch-picker",
  "build": {
    "beforeDevCommand": "bun run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Model Dispatch",
        "width": 760,
        "height": 560,
        "center": true,
        "decorations": false,
        "shadow": true,
        "transparent": true,
        "theme": "Dark",
        "resizable": true,
        "alwaysOnTop": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
